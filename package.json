{
  "name": "openclaw-token-optimizer",
  "version": "1.1.0",
  "description": "Optimise token consumption in OpenClaw by 70-90% using vector embeddings and semantic search",
  "main": "dist/src/index.js",
  "bin": {
    "openclaw-token-optimizer": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "setup": "node dist/scripts/setup.js",
    "test": "node dist/scripts/test.js",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "analyze": "node dist/src/index.js analyze",
    "stats": "node dist/src/index.js stats",
    "index": "node dist/src/index.js index",
    "maintenance": "node dist/scripts/maintenance.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "token-optimization",
    "vector-embeddings",
    "semantic-search",
    "ai",
    "memory-optimization"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw-community/openclaw-token-optimizer.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw-community/openclaw-token-optimizer/issues"
  },
  "homepage": "https://github.com/openclaw-community/openclaw-token-optimizer#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "vectra": "^0.5.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/jwt-decode": "^2.2.1",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist/",
    "src/",
    "bin/",
    "docs/",
    "examples/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  }
}
